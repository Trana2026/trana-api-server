# 로컬 개발 환경 설정 — 템플릿
# 이 파일을 application-local.yml로 복사한 후 placeholder 값을 채우세요.
# 시크릿 생성:
#   openssl rand -base64 32    # JWT secret / crypto password
#   openssl rand -hex 16       # crypto salt
spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/trana
    username: trana
    password: trana1234
    driver-class-name: org.postgresql.Driver
  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: true
    properties:
      hibernate:
        format_sql: true
  flyway:
    enabled: true
    baseline-on-migrate: false
    locations: classpath:db/migration

trana:
  jwt:
    issuer: trana
    audience: trana-app
    secret: <REPLACE_WITH_openssl_rand_base64_32>
    access-token-ttl: PT15M
    refresh-token-ttl: P1825D
  crypto:
    password: <REPLACE_WITH_openssl_rand_base64_32>
    salt: <REPLACE_WITH_openssl_rand_hex_16>
  dev:
    token-key: local-dev-token-key-change-me
  identity:
    pass:
      # mok_keyInfo.dat 파일을 base64 인코딩한 한 줄
      #   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("mok_keyInfo.dat"))
      #   Git Bash:   base64 -w0 mok_keyInfo.dat
      key-info-base64: <REPLACE_WITH_BASE64_OF_mok_keyInfo.dat>
      key-info-password: <REPLACE_WITH_mobileOK_password>
      mobile-ok-base-url: https://scert.mobile-ok.com
      return-url: http://localhost:8080/v1/identity/pass/return
  storage:
    s3:
      region: ap-northeast-2
      access-key: <AWS IAM trana-server Access Key ID>
      secret-key: <AWS IAM trana-server Secret Access Key>
  pdf-archive:
      bucket: trana-pdf
      presigned-get-ttl-minutes: 10
  web:
      base-url: http://localhost:3000
  alimtalk:
      aligo:
       api-key: <알리고 API Key>
       user-id: <알리고 로그인 ID>
       sender-key: <알리고 카카오 발신프로필 Sender Key>
       sender: <알리고 등록 발신번호 (예: 0212345678, '-' 없이)>
       test-mode: true
       tpl-code:
         new-contract: UI_4032
         receiver-signed: UI_4033
         revision-requested: UI_4034
         completed: UI_4037
         dispute-reported: UI_PENDING_DISPUTE_REGISTRATION
         cancellation-requested: UI_PENDING_CANCELLATION_REGISTRATION
  fcm:
       service-account-base64: <base64 인코딩한 firebase-adminsdk-xxx.json 한 줄 — 비워두면 Mock>
  slack:
       webhook-url: https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX
