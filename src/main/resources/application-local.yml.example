# 로컬 개발 환경 설정 — 템플릿
# 이 파일을 application-local.yml로 복사한 후 placeholder 값을 채우세요.
# 시크릿 생성:
#   openssl rand -base64 32    # JWT secret / crypto password
#   openssl rand -hex 16       # crypto salt
spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/trana
    username: trana
    password: trana1234
    driver-class-name: org.postgresql.Driver
  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: true
    properties:
      hibernate:
        format_sql: true
  flyway:
    enabled: true
    baseline-on-migrate: false
    locations: classpath:db/migration

trana:
  jwt:
    issuer: trana
    audience: trana-app
    secret: <REPLACE_WITH_openssl_rand_base64_32>
    access-token-ttl: PT15M
    refresh-token-ttl: P30D
  crypto:
    password: <REPLACE_WITH_openssl_rand_base64_32>
    salt: <REPLACE_WITH_openssl_rand_hex_16>
  oauth:
    kakao:
      issuer: https://kauth.kakao.com
      client-id: <Kakao Developers Console의 REST API 키>
      native-app-key: <Kakao Developers Console의 네이티브 앱 키>
    google:
      issuer: https://accounts.google.com
      client-id:
    apple:
      issuer: https://appleid.apple.com
      bundle-id: <Apple App Bundle ID — 예: kr.trana.app>
      client-id: <Apple Services ID — 예: kr.trana.app.service>
      team-id: <Apple Developer Team ID (10자)>
      key-id: <Sign in with Apple Key ID (10자)>
      private-key: |
        -----BEGIN PRIVATE KEY-----
        REPLACE_WITH_p8_FILE_CONTENT
        -----END PRIVATE KEY-----
      android-package-name: <Flutter Android package — 예: kr.trana.app>
  dev:
    token-key: local-dev-token-key-change-me
  kyc:
    ncp:
      id-card:
        invoke-url: https://CHANGE_ME.apigw-pub.fin-ntruss.com/ekyc/v1/CHANGE_ME/CHANGE_ME/id-card
        secret-key: CHANGE_ME
      face-compare:
        invoke-url: https://CHANGE_ME.apigw-pub.fin-ntruss.com/ekyc/v1/CHANGE_ME/CHANGE_ME/face-compare
        secret-key: CHANGE_ME
  storage:
    s3:
      bucket: trana-temp-dev
      region: ap-northeast-2
      access-key: <AWS IAM trana-server Access Key ID>
      secret-key: <AWS IAM trana-server Secret Access Key>
  pdf-archive:
      bucket: trana-pdf
      presigned-get-ttl-minutes: 10
  web:
      base-url: http://localhost:3000
  alimtalk:
      aligo:
       api-key: <알리고 API Key>
       user-id: <알리고 로그인 ID>
       sender-key: <알리고 카카오 발신프로필 Sender Key>
       sender: <알리고 등록 발신번호 (예: 0212345678, '-' 없이)>
       test-mode: true
       tpl-code:
         new-contract: UI_4032
         receiver-signed: UI_4033
         revision-requested: UI_4034
         completed: UI_4037
         dispute-reported: UI_PENDING_DISPUTE_REGISTRATION
         cancellation-requested: UI_PENDING_CANCELLATION_REGISTRATION
  fcm:
       service-account-base64: <base64 인코딩한 firebase-adminsdk-xxx.json 한 줄 — 비워두면 Mock>
  slack:
       webhook-url: https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX
